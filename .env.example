# TMS TCP connection
TMS_HOST=your-tms-host.example.com
TMS_PORT=17159
TMS_AUTH_TOKEN=your-tms-token-here

# Bearer token that HappyRobot sends on every REST call
API_AUTH_TOKEN=changeme

# Socket / retry tuning (optional — defaults shown)
SOCKET_TIMEOUT=10.0
MAX_RETRIES=3
RETRY_BACKOFF_BASE=0.5

# FMCSA QCMobile API (carrier verification) — optional, used by preflight.py
# Get a web key at https://mobile.fmcsa.dot.gov/QCDevsite/docs/getStarted
FMCSA_WEB_KEY=
# Set ONE of these to a real, known-valid identifier for the preflight test lookup.
# DOT number takes precedence over MC/docket number if both are set.
FMCSA_TEST_DOT=
FMCSA_TEST_MC=

# Deployed service URL, once the API has been deployed — optional, used by preflight.py
PUBLIC_BASE_URL=
